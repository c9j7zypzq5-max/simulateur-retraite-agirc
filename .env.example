# Stripe — brancher vos clés sur https://dashboard.stripe.com/apikeys
# En développement, utiliser les clés de test (préfixe sk_test_ / pk_test_)
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ID du prix récurrent Stripe pour l'abonnement Pro 2,99€/mois
# Créer via Dashboard → Products → Add product → Recurring 2,99€
STRIPE_PRO_PRICE_ID=price_...

# Upstash Redis (déjà configuré si vous utilisez le tracking de vues)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Supabase — authentification + base de données (comptes, simulations)
# Dashboard Supabase → Project Settings → API
# VITE_* = exposé au navigateur (normal pour l'URL et la clé anon, publiques)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Clé service_role : SERVEUR UNIQUEMENT (jamais de préfixe VITE_).
# Utilisée par le webhook Stripe pour écrire le statut d'abonnement.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
